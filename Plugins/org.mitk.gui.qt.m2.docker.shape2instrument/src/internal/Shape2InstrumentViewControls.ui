    <widget class="QLabel" name="labelMask">
     <property name="text"><string>Multi-label mask (LabelSetImage)</string></property>
    </widget>
   </item>
   <item>
    <widget class="QmitkSingleNodeSelectionWidget" name="maskSelection" native="true"/>
   </item>

