     <property name="text"><string>Calibration PointSet (3 points)</string></property>
    </widget>
   </item>
   <item>
    <layout class="QHBoxLayout" name="mpsLayout">
     <item>
      <widget class="QmitkSingleNodeSelectionWidget" name="mpsSelection" native="true"/>
