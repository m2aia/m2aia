<ui version="4.0">
 <class>Shape2InstrumentViewControls</class>
 <widget class="QWidget" name="Shape2InstrumentViewControls">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>340</width><height>560</height></rect>
  </property>
  <property name="windowTitle">
   <string>Shape2Instrument</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">

   <!-- Description -->
   <item>
    <widget class="QLabel" name="descLabel">
     <property name="text">
      <string>Converts a multi-label NRRD mask and 3 calibration points (MPS PointSet) into a Leica XML or MMI CSV instrument file via Docker.</string>
     </property>
     <property name="wordWrap"><bool>true</bool></property>
    </widget>
   </item>

   <!-- Mask selection -->
